{
  "name": "guandan-lan",
  "version": "1.5.0",
  "description": "掼蛋 - 安庆热门扑克游戏局域网版",
  "main": "guandan-server.js",
  "scripts": {
    "start": "node guandan-server.js",
    "dev": "nodemon guandan-server.js",
    "dev:verbose": "nodemon guandan-server.js --verbose",
    "test": "jest --colors",
    "test:watch": "jest --watch --colors",
    "test:coverage": "jest --coverage --colors"
  },
  "nodemonConfig": {
    "watch": [
      "guandan-server.js",
      "guandan-lan.html"
    ],
    "ext": "js html",
    "ignore": [
      "node_modules/*",
      "*.md"
    ],
    "delay": 1000,
    "verbose": true,
    "execMap": {
      "js": "node"
    }
  },
  "keywords": [
    "guandan",
    "card-game",
    "lan-game",
    "websocket",
    "multiplayer"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.0"
  }
}
